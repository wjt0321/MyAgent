# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf linguist-language=Python linguist-detectable=true

# Web files
*.js text eol=lf linguist-language=JavaScript linguist-detectable=true
*.css text eol=lf linguist-language=CSS linguist-detectable=true
*.html text eol=lf linguist-language=HTML linguist-detectable=true

# Un-vendor static directory (GitHub Linguist ignores `static/` by default)
src/myagent/web/static/** linguist-vendored=false

# Markdown files (Marked as documentation so they don't skew the language stats)
*.md text eol=lf linguist-documentation

# YAML files
*.yaml text eol=lf
*.yml text eol=lf

# Docker
Dockerfile text eol=lf

# SVG
*.svg text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
