# MyAgent Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================================
# LLM Providers (choose at least one)
# ============================================================

# OpenAI (GPT-4o, GPT-4o-mini, etc.)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o

# Anthropic (Claude 3.5/4 Sonnet, Opus)
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# DeepSeek (V3, R1)
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# Google Gemini (1.5 Pro, Flash)
# GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_MODEL=gemini-1.5-pro

# Alibaba Qwen (Qwen-Max, Plus)
# QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# QWEN_MODEL=qwen-max

# SiliconFlow (aggregated Chinese models)
# SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# Zhipu AI (GLM-4, GLM-4V, etc.)
ZHIPU_API_KEY=764e8bd9496b45ba96f39838109e577a.6ovSuDLgk20dX4yS
ZHIPU_MODEL=glm-4.7

# Azure OpenAI Service
# AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_MODEL=gpt-4o

# OpenRouter (unified API for many models)
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Ollama (local models - llama3, mistral, etc.)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ============================================================
# Gateway Platforms (enable the ones you need)
# ============================================================

# Feishu / Lark (飞书)
# FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx

# Discord
# DISCORD_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx.xxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram
# TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DingTalk (钉钉)
# DINGTALK_CLIENT_ID=dingxxxxxxxxxxxxxxxx
# DINGTALK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WeCom (企业微信)
# WECOM_BOT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WECOM_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Weixin (微信公众号)
# WEIXIN_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WEIXIN_ACCOUNT_ID=gh_xxxxxxxxxxxx

# QQ
# QQ_APP_ID=xxxxxxxxxx
# QQ_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# Matrix
# MATRIX_ACCESS_TOKEN=syt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MATRIX_HOMESERVER=https://matrix.org

# ============================================================
# MyAgent Settings
# ============================================================

# Webhook secret (auto-generated if not set)
# WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default model (overrides provider-specific defaults)
# MYAGENT_MODEL_DEFAULT=anthropic/claude-sonnet-4

# Session reset mode: daily, idle, both, none
# SESSION_RESET_MODE=both

# Session idle timeout in minutes
# SESSION_IDLE_MINUTES=1440

# Session reset hour (0-23)
# SESSION_RESET_HOUR=4
